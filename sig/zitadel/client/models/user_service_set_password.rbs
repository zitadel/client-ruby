module Zitadel::Client::Models
  class UserServiceSetPassword < Dry::Struct
    ATTRIBUTE_MAP: Hash[Symbol, String]
    JSON_KEY_MAP: Hash[String, Symbol]
    OPENAPI_TYPES: Hash[Symbol, String]
    OPENAPI_FORMATS: Hash[Symbol, String]
    attr_reader hashed_password: UserServiceHashedPassword?
    attr_reader password: UserServicePassword?
    attr_reader current_password: String?
    attr_reader verification_code: String?
  end
end
